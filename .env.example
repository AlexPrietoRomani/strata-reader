# Strata-Reader environment variables. Copy to `.env` and adjust.

# Ollama endpoint for VLM/OCR tasks (see Plan Maestro §10).
STRATA_OLLAMA_URL=http://localhost:11434

# VRAM budget (in MB) the IA layer is allowed to use before back-pressuring.
STRATA_GPU_LIMIT_VRAM_MB=6000

# Max number of pages processed in parallel by the Rust scheduler (§13).
STRATA_MAX_CONCURRENT_PAGES=4

# Triage profile: fast | balanced | scientific (§9).
STRATA_PROFILE=balanced

# Logging — RUST_LOG syntax (tracing-subscriber).
RUST_LOG=info,strata_=debug

# uv link mode — keep "copy" while the repo lives under OneDrive.
UV_LINK_MODE=copy
